{{#each items}}
    <tr class="item-option{{#if (and ../selectedItem (eq ../selectedItem uuid))}} selected{{/if}}" data-item-id="{{uuid}}" data-tooltip="{{tooltip}}">
        <td class="item-cell-img">
            <img src="{{img.display}}" alt="{{name.display}}" loading="lazy" class="item-row-img">
        </td>
        <td class="item-cell-name" colspan="2">
            <p class="item-row-text">{{name.display}}</p>
        </td>
        {{{rowHtml}}}
    </tr>
{{/each}}